---
import '../styles/global.css';

import { ClientRouter } from 'astro:transitions';
import BackToTop from '../components/BackToTop.astro';
import FloodingMask from '../components/FloodingMask.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Astro + React blog site" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />

		{/* 极简行内脚本，防止主题闪烁 (FOUC) 并适配 ClientRouter 切换 */}
		<script is:inline>
			const getTheme = () => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			};

			const applyTheme = (doc = document) => {
				const theme = getTheme();
				if (theme === 'dark') {
					doc.documentElement.classList.add('dark');
				} else {
					doc.documentElement.classList.remove('dark');
				}
			};

			// 初始运行
			applyTheme();

			// 页面切换前锁定新页面的主题 (防止闪现白色)
			document.addEventListener('astro:before-swap', (ev) => {
				applyTheme(ev.newDocument);
			});
		</script>
	</head>
	<body class="antialiased min-h-screen bg-white dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 transition-colors duration-700 ease-in-out selection:bg-blue-100 dark:selection:bg-blue-900/40 tracking-wide leading-relaxed">
		<FloodingMask />
		<slot />
		<BackToTop />
	</body>
</html>
