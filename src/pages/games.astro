---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import EmptyState from '../components/EmptyState';
---

<Layout title="游戏 - Yama Blog">
	<Header client:load pathname={Astro.url.pathname} />
	
	<main class="pt-32 pb-20 px-6 max-w-4xl mx-auto">
		<article class="bg-white dark:bg-zinc-900/40 rounded-[2.5rem] border border-zinc-200/50 dark:border-zinc-800/50 shadow-2xl p-8 md:p-12 lg:p-16">
			<header class="mb-12 text-center">
				<h1 class="text-4xl font-bold text-zinc-900 dark:text-zinc-100 mb-6 tracking-tight">互动游戏区</h1>
				<p class="text-zinc-500 dark:text-zinc-400 text-lg">WebGL、Canvas 与各种有趣的 Web 技术实验。</p>
			</header>
			
			<EmptyState 
				client:load 
				title="游戏实验室构建中" 
				message="博主正在研究如何在浏览器里塞进一个坦克大战或是复古闯关游戏，就在不远的将来！" 
			/>
		</article>
	</main>
</Layout>
