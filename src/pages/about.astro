---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header';
import AboutProfile from '../components/AboutProfile';
---

<Layout title="关于 - Yama Blog">
	<Header client:load pathname={Astro.url.pathname} />
	
	<main class="pt-32 pb-20 px-6 max-w-4xl mx-auto text-zinc-900 dark:text-zinc-100">
		<article class="bg-white dark:bg-zinc-900/40 rounded-[2.5rem] border border-zinc-200/50 dark:border-zinc-800/50 shadow-2xl p-8 md:p-12 lg:p-16">
			<AboutProfile client:load />
		</article>
	</main>
</Layout>
